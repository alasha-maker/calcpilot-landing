{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "calcpilot-landing",
  "main": "./worker.js",
  "compatibility_date": "2024-09-23",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    {
      "binding": "APP_BUCKET",
      "bucket_name": "calcpilot-app"
    }
  ]
}
