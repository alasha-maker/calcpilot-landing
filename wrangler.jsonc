{
  // Tells Cloudflare's Wrangler to deploy this project as a static-assets
  // Worker (i.e. a CDN-hosted site), not a JavaScript Worker script.
  // Build step (npm run build) produces ./dist; this config points at it.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "calcpilot-landing",
  "compatibility_date": "2024-09-23",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
